{
  "color": {
    "surface": {
      "bg-0": "#F7F7FA",
      "bg-1": "#FFFFFF",
      "bg-2": "#F2EFF6",
      "bg-3": "#ECE9F1",
      "bg-4": "#E3DFE8"
    },
    "line": {
      "line": "#E3DFE8",
      "line-soft": "#EEEAF2",
      "ring-track": "#ECE9F1"
    },
    "text": {
      "t-1": "#15131A",
      "t-2": "#4A4553",
      "t-3": "#8A8496",
      "t-4": "#B6B1C1"
    },
    "accent": {
      "accent": "#7E2C8C",
      "accent-2": "#9C3FB0",
      "accent-soft": "#F3E8F7",
      "accent-line": "#E1CCE8"
    },
    "status": {
      "top_performer": { "label": "Scale",  "color": "#177C63", "bg": "#E6F4EF" },
      "stable":        { "label": "Watch",  "color": "#6B4FB8", "bg": "#EFEBF8" },
      "fatigued":      { "label": "Rescue", "color": "#C26A1E", "bg": "#FAEEDE" },
      "underperformer":{ "label": "Cut",    "color": "#B5475C", "bg": "#F7E4E8" }
    },
    "healthGradient": [
      { "min": 70, "max": 100, "color": "#177C63" },
      { "min": 40, "max": 69,  "color": "#7E2C8C" },
      { "min": 0,  "max": 39,  "color": "#B5475C" }
    ]
  },
  "font": {
    "sans": "'Inter', system-ui, -apple-system, sans-serif",
    "mono": "'Roboto Mono', ui-monospace, Menlo, monospace",
    "numeric": "'Roboto Mono', 'Inter', sans-serif"
  },
  "type": {
    "page":      { "size": 28, "weight": 700, "letterSpacing": "-0.02em", "lineHeight": 1.15 },
    "section":   { "size": 18, "weight": 600, "letterSpacing": "-0.01em", "lineHeight": 1.25 },
    "body":      { "size": 13, "weight": 400, "lineHeight": 1.5 },
    "td":        { "size": 13, "weight": 500, "lineHeight": 1.35 },
    "micro":     { "size": 11, "weight": 500, "lineHeight": 1.4, "color": "t-3" },
    "overline":  { "size": 10, "weight": 600, "letterSpacing": "0.08em", "textTransform": "uppercase", "color": "t-3" },
    "labelXs":   { "size": 10, "weight": 600, "letterSpacing": "0.04em", "textTransform": "uppercase", "color": "t-3" },
    "num": {
      "s":  { "size": 18, "weight": 600 },
      "m":  { "size": 22, "weight": 600 },
      "l":  { "size": 32, "weight": 600 },
      "xl": { "size": 44, "weight": 600 }
    },
    "healthRing": { "number": { "size": 14, "weight": 700 }, "label": { "size": 11, "weight": 500 } }
  },
  "spacing": {
    "page-x": 32,
    "page-y": 24,
    "card-pad": 20,
    "stack": [2, 4, 6, 8, 12, 16, 20, 24, 32, 40, 48]
  },
  "radius": {
    "pill": 999,
    "chip": 8,
    "button": 8,
    "card-s": 8,
    "card":   10,
    "card-l": 14
  },
  "shadow": {
    "none":   "none",
    "1":      "0 1px 2px rgba(20,19,26,0.04)",
    "card":   "0 1px 3px rgba(20,19,26,0.05), 0 1px 2px rgba(20,19,26,0.04)",
    "drawer": "-16px 0 48px rgba(20,19,26,0.14)"
  },
  "motion": {
    "t-fast": "120ms",
    "t-tab":  "180ms",
    "t-drawer": "260ms",
    "ease-out": "cubic-bezier(0.2, 0.8, 0.2, 1)"
  },
  "rowHeights": { "compact": 64, "regular": 80, "relaxed": 96 },
  "statusTabs": [
    { "key": "scale",  "status": "top_performer",  "label": "Scale",  "urgent": false },
    { "key": "watch",  "status": "stable",         "label": "Watch",  "urgent": false },
    { "key": "rescue", "status": "fatigued",       "label": "Rescue", "urgent": true  },
    { "key": "cut",    "status": "underperformer", "label": "Cut",    "urgent": true  },
    { "key": "explore","status": null,             "label": "Explore","utility": true }
  ]
}
